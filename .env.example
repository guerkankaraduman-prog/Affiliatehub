# =========================
# Backend
# =========================
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,tower_http=debug
ENVIRONMENT=development

DATABASE_URL=postgres://affiliate:affiliate_dev_password@localhost:5432/affiliate_platform
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5

CLERK_SECRET_KEY=sk_live_replace_with_backend_secret
CLERK_PUBLISHABLE_KEY=pk_live_replace_with_publishable_key
CLERK_JWKS_URL=https://clerk.affiliateplatform.local/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_live_replace_with_webhook_secret
CLERK_ISSUER=https://clerk.affiliateplatform.local

ALLOWED_ORIGINS=http://localhost:3000,https://affiliateplatform.com
FRONTEND_URL=http://localhost:3000

ATTRIBUTION_WINDOW_DAYS=30
CLICK_DEDUP_WINDOW_SECONDS=1800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

DEFAULT_COMMISSION_RATE=10.00
AUTO_APPROVAL_DAYS=14
MIN_PAYOUT_AMOUNT=50.00

RATE_LIMIT_ANONYMOUS=60
RATE_LIMIT_AUTHENTICATED=120
RATE_LIMIT_TRACKING=120

MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

POSTHOG_API_KEY=phc_live_replace_with_backend_key
POSTHOG_HOST=https://app.posthog.com

REDIS_URL=redis://localhost:6379

FLY_APP_NAME=affiliate-platform-api
FLY_REGION=iad

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_URL=http://localhost:8080/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_with_publishable_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

NEXT_PUBLIC_POSTHOG_KEY=phc_live_replace_with_frontend_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

NEXT_PUBLIC_APP_NAME=Affiliate Platform
NEXT_PUBLIC_TRACKING_DOMAIN=https://api.affiliateplatform.com

VERCEL_URL=affiliateplatform.vercel.app
VERCEL_ORG_ID=team_replace_with_org_id
VERCEL_PROJECT_ID=prj_replace_with_project_id
VERCEL_TOKEN=replace_with_vercel_token
FLY_API_TOKEN=replace_with_fly_api_token
